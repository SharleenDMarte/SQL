--This project analyzes transactional and customer data from the Chinook Sample Database using SQL.
--Tools & Techniques Used (SQL, Chinook Sample Database, Joins, Aggregations, Date filtering)
--#1. What countries do our customers come from outside of the United States? 
SELECT CustomerId, 
FirstName || ' ' || LastName AS FullName, Country 
FROM customers 
WHERE Country <> 'USA';

--#2. Which customers are located in Brazil and how active are they? 
SELECT c.CustomerId, c.FirstName || ' ' || c.LastName AS FullName, COUNT(i.InvoiceId) AS NumberOfPurchases, SUM(i.Total) AS TotalSpent 
FROM customers c 
LEFT JOIN invoices i 
ON c.CustomerId = i.CustomerId 
WHERE c.Country = 'Brazil' 
GROUP BY c.CustomerId, FullName;

--#3. What invoices were generated by customers from Brazil? 
SELECT c.FirstName || ' ' || c.LastName AS CustomerName, i.InvoiceId, i.InvoiceDate, i.BillingCountry, i.Total 
FROM customers c 
LEFT JOIN invoices i 
ON c.CustomerId = i.CustomerId 
WHERE country = 'Brazil';

----#4. Which employees are responsible for sales? 
SELECT e.EmployeeId, e.FirstName || ' ' || e.LastName AS SalesAgent, COUNT(c.CustomerId) AS CustomersManaged 
FROM employees e 
LEFT JOIN customers c 
ON e.EmployeeId = c.SupportRepId 
WHERE e.Title = 'Sales Support Agent' 
GROUP BY e.EmployeeId, SalesAgent;

--#5. How are invoices distributed across sales agents? 
SELECT e.FirstName || ' ' || e.LastName AS SalesAgent, COUNT(i.InvoiceId) AS NumberOfInvoices, SUM(i.Total) AS TotalSales 
FROM invoices i 
JOIN customers c 
ON i.CustomerId = c.CustomerId 
JOIN employees e 
ON c.SupportRepId = e.EmployeeId 
GROUP BY SalesAgent 
ORDER BY TotalSales DESC;

--#6. What were the total sales for the year 2009? 
SELECT COUNT(InvoiceId) AS TotalInvoices, SUM(Total) AS TotalSales2009 
FROM invoices 
WHERE InvoiceDate LIKE '%2009%';

--#7. Which sales agent generated the most revenue in 2009? 
SELECT e.FirstName || ' ' || e.LastName AS SalesAgent, COUNT(i.InvoiceId) AS NumberOfInvoices, SUM(i.Total) AS TotalSales, i.InvoiceDate 
FROM invoices i 
JOIN customers c 
ON i.CustomerId = c.CustomerId 
JOIN employees e 
ON c.SupportRepId = e.EmployeeId 
WHERE InvoiceDate LIKE '%2009%' 
GROUP BY SalesAgent 
ORDER BY TotalSales DESC;

--Key Takeaways
--#1. The digital music store operates in a global marketplace with international purchasing activity.
--#2. Customers located in Brazil generated multiple invoices and repeat purchases, demonstrating that Brazil represents an active international market segment within the customer base.
--#3. Sales revenue and invoices can be directly attributed to individual sales agents. By joining the employees, customers, and invoices tables, it was possible to determine how invoices and revenue are distributed among sales agents and identify which employee generated the highest sales revenue in 2009.
