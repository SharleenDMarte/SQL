-- Spotify Data Analysis Using SQL

-- In this project I analyzed Spotify data downloaded from Kaggle.
-- I created a SQL table to store the dataset and imported the CSV file.
-- Using SQL queries, I explored song popularity, artist frequency, and relationships between musical characteristics such as danceability,energy, tempo, and song duration.

--Creating the table:
CREATE TABLE BIT_DB.Spotifydata (
id integer PRIMARY KEY,
artist_name varchar NOT NULL,
track_name varchar NOT NULL,
track_id varchar NOT NULL,
popularity integer NOT NULL,
danceability decimal(4,3) NOT NULL,
energy decimal(4,3) NOT NULL,
song_key integer NOT NULL,
loudness decimal(5,3) NOT NULL,
song_mode integer NOT NULL,
speechiness decimal(5,4) NOT NULL,
acousticness decimal(6,5) NOT NULL,
instrumentalness decimal(8,7) NOT NULL,
liveness decimal(5,4) NOT NULL,
valence decimal(4,3) NOT NULL,
tempo decimal(6,3) NOT NULL,
duration_ms integer NOT NULL,
time_signature integer NOT NULL );

--I explored the following data using the following SQL. 

--#1.Which song has the highest popularity score, and which artist performed it?
SELECT artist_name, track_name
FROM Spotifydata 
ORDER BY popularity DESC
LIMIT 1;

--#2. Which artist appears the most times in the dataset?
SELECT artist_name,COUNT(*) AS song_count
FROM Spotifydata
GROUP BY artist_name
ORDER BY song_count DESC
LIMIT 1;

--#3. Is there a relationship between danceability and popularity?
SELECT track_name, danceability, popularity
FROM Spotifydata
ORDER BY danceability DESC;

--#4. Which song has the highest energy?
SELECT artist_name, track_name, energy
FROM Spotifydata
ORDER BY energy DESC
LIMIT 1;

--#5. What is the average tempo of the songs in the dataset?
SELECT AVG(tempo) AS avg_tempo
FROM Spotifydata;

--#6. Do songs in a major key (mode = 1) have higher average popularity than songs in a minor key (mode = 0)?
SELECT song_mode, AVG(popularity) AS avg_popularity
FROM Spotifydata
GROUP BY song_mode;

--7. Which song has the longest duration?
SELECT artist_name, track_name, duration_ms
FROM Spotifydata
ORDER BY duration_ms DESC
LIMIT 1;

--Key Takeaways
--1. By identifying the most popular songs and the artists who appear most frequently in the dataset, I demonstrated how SQL aggregation and sorting can highlight top-performing content and artist presence within a music catalog.
--2. By examining musical attributes such as danceability, energy, tempo, and duration, I explored how song characteristics vary across tracks and how these features may influence listener engagement and popularity.
--3. By comparing average popularity between songs in major and minor keys, I used SQL grouping and aggregation to uncover subtle patterns in musical composition that may correlate with audience preference.
